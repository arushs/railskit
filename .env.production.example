# RailsKit Production Environment Configuration
# Copy to .env.production and fill in real values
# ================================================

# --- Rails Core ---
RAILS_ENV=production
SECRET_KEY_BASE=          # Generate with: bin/rails secret
RAILS_LOG_TO_STDOUT=true
RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# --- Database ---
DATABASE_URL=postgres://user:password@host:5432/railskit_production

# --- Redis (optional — for caching/ActionCable if not using Solid adapters) ---
REDIS_URL=redis://localhost:6379/0

# --- Background Jobs ---
# Run Solid Queue inside Puma (good for single-server deploys)
SOLID_QUEUE_IN_PUMA=true

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.example.com

# --- Stripe (if billing enabled) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- AI / Agents (if agent features enabled) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Vite Frontend (build-time) ---
VITE_API_URL=https://your-api.example.com
