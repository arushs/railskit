# Rails API
DATABASE_URL=postgres://railskit:railskit@localhost:5432/railskit_development
REDIS_URL=redis://localhost:6379/0
RAILS_ENV=development
CORS_ORIGINS=http://localhost:5173

# Email — set based on railskit.yml email.provider
# Resend (default)
RESEND_API_KEY=

# Postmark (if email.provider: postmark)
# POSTMARK_API_TOKEN=

# Generic SMTP (if email.provider: smtp)
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_DOMAIN=

# Vite (web)
VITE_API_URL=
