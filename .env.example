# Rails API
DATABASE_URL=postgres://railskit:railskit@localhost:5432/railskit_development
REDIS_URL=redis://localhost:6379/0
RAILS_ENV=development
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
SECRET_KEY_BASE=generate-with-rails-secret

# Auth - JWT
DEVISE_JWT_SECRET_KEY=generate-with-rails-secret

# Auth - Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth - Mailer sender
DEVISE_MAILER_SENDER=noreply@example.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# AI
OPENAI_API_KEY=

# Fireworks AI (for embeddings — default RAG provider)
FIREWORKS_API_KEY=

# Auth provider: devise_jwt (default) | supabase | clerk
AUTH_PROVIDER=devise_jwt

# JWT secret (auto-falls back to Rails secret_key_base if unset)

# Google OAuth (optional — omit to disable Google sign-in)

# Frontend URL (for OAuth redirects and magic link emails)

# Vite (web)
VITE_API_URL=
