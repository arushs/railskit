<h2>You're all set! 🎉</h2>

<p>
  Thanks for subscribing to <strong><%= @app_name %></strong>,
  <%= @user.try(:name) || @user.email.split("@").first %>.
</p>

<table style="width: 100%; margin: 24px 0; border: 1px solid #eeeeee; border-radius: 6px; overflow: hidden;">
  <tr style="background-color: #f9f9fb;">
    <td style="padding: 12px 16px; font-weight: 600; color: #666;">Plan</td>
    <td style="padding: 12px 16px;"><%= @subscription.try(:plan_name) || @subscription[:plan_name] %></td>
  </tr>
  <tr>
    <td style="padding: 12px 16px; font-weight: 600; color: #666;">Status</td>
    <td style="padding: 12px 16px;">
      <span style="background-color: #d4edda; color: #155724; padding: 2px 8px; border-radius: 4px; font-size: 14px;">Active</span>
    </td>
  </tr>
  <tr style="background-color: #f9f9fb;">
    <td style="padding: 12px 16px; font-weight: 600; color: #666;">Next billing date</td>
    <td style="padding: 12px 16px;"><%= @subscription.try(:current_period_end)&.strftime("%B %d, %Y") || "—" %></td>
  </tr>
</table>

<a href="<%= @manage_url %>" class="btn">Manage Subscription</a>

<p class="muted">You can update your plan or cancel anytime from your billing portal.</p>
