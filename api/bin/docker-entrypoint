#!/bin/bash -e

# Run db:prepare before server start — unless SKIP_DB_PREPARE is set.
# Fly.io uses release_command for migrations (set SKIP_DB_PREPARE=1 there),
# Render/Docker rely on this entrypoint.
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  if [ "${SKIP_DB_PREPARE}" != "1" ]; then
    ./bin/rails db:prepare
  fi
fi

exec "${@}"
